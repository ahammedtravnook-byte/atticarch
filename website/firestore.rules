rules_version = '2';

// ════════════════════════════════════════════════════════════════════
//  ATTICARCH Firestore security rules
//
//  Model:
//   • Public website content (projects, blog, settings…) is READ-ONLY to
//     the world and writable only by admins.
//   • Leads (contact-form submissions) can be CREATED by anyone but are
//     READABLE only by admins — they contain customer PII.
//   • Admins are identified by email via the `settings/admins` doc, with a
//     hard-coded bootstrap list below so the first admin can sign in before
//     that doc exists.
//
//  ⚠️  BEFORE DEPLOYING: replace the bootstrap email(s) in bootstrapAdmins()
//      with your real admin email(s). Keep this list in sync with the
//      VITE_ADMIN_EMAILS value in your .env file.
// ════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // Bootstrap admins — these Firebase Auth accounts already exist and are
    // controlled by the owners, so no email_verified requirement here (an
    // attacker cannot register a duplicate of an already-claimed email).
    function bootstrapAdmins() {
      return ['owner@atticarch.com', 'ahammed.travnook@gmail.com'];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function emailLower() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    function adminDocExists() {
      return exists(/databases/$(database)/documents/settings/admins);
    }

    function adminEmails() {
      return get(/databases/$(database)/documents/settings/admins).data.emails;
    }

    // Bootstrap admins are trusted by account ownership (their accounts are
    // already registered, and Firebase enforces unique emails). Emails added
    // later via settings/admins MUST be verified: email/password signup lets
    // anyone register a not-yet-claimed address without proving they own the
    // mailbox, so an unverified claim must never grant admin access.
    function isAdmin() {
      return isSignedIn() && (
        emailLower() in bootstrapAdmins() ||
        (
          request.auth.token.email_verified == true
          && adminDocExists() && emailLower() in adminEmails()
        )
      );
    }

    // ── Public, admin-writable content collections ──
    match /projects/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /categories/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /blogPosts/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /services/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /rooms/{id}            { allow read: if true; allow write: if isAdmin(); }
    match /team/{id}             { allow read: if true; allow write: if isAdmin(); }
    match /partners/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /upcomingProjects/{id} { allow read: if true; allow write: if isAdmin(); }

    // ── Settings ──
    // homepage / landingpage / about are read by the public site.
    // `admins` (the allowlist) is readable by admins only — it holds emails.
    match /settings/{id} {
      allow read:  if id != 'admins' || isAdmin();
      allow write: if isAdmin();
    }

    // ── Leads (contact form) ──
    // Anyone may submit a lead; only admins may read/modify them (PII).
    // Creates are validated: only known fields, sane types/sizes, and the
    // `verified` flag may only be true when the request is phone-authenticated
    // (i.e. the OTP step actually completed) — otherwise it is spoofable.
    match /leads/{id} {
      allow create: if
        request.resource.data.keys().hasOnly([
          'id', 'name', 'email', 'phone', 'projectType', 'size', 'possession',
          'location', 'budget', 'message', 'timeline', 'verified', 'source', 'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 20
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 200
        && request.resource.data.verified is bool
        && (request.resource.data.verified == false || isSignedIn())
        && (!('message' in request.resource.data) || (request.resource.data.message is string && request.resource.data.message.size() <= 5000))
        && (!('projectType' in request.resource.data) || (request.resource.data.projectType is string && request.resource.data.projectType.size() <= 100))
        && (!('size' in request.resource.data) || (request.resource.data.size is string && request.resource.data.size.size() <= 100))
        && (!('possession' in request.resource.data) || (request.resource.data.possession is string && request.resource.data.possession.size() <= 100))
        && (!('location' in request.resource.data) || (request.resource.data.location is string && request.resource.data.location.size() <= 300))
        && (!('budget' in request.resource.data) || (request.resource.data.budget is string && request.resource.data.budget.size() <= 100))
        && (!('source' in request.resource.data) || (request.resource.data.source is string && request.resource.data.source.size() <= 50))
        && (!('createdAt' in request.resource.data) || (request.resource.data.createdAt is string && request.resource.data.createdAt.size() <= 50));
      allow read, update, delete: if isAdmin();
    }

    // ── Default deny everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
